{
  "expo": {
    "name": "OpenClaw",
    "slug": "openclaw",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "openclaw",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#09090e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.openclaw.app",
      "infoPlist": {
        "UIBackgroundModes": ["fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090e"
      },
      "package": "com.openclaw.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "OpenClaw",
      "shortName": "OpenClaw",
      "description": "OpenClaw AI Agent Management Dashboard",
      "themeColor": "#09090e",
      "backgroundColor": "#09090e",
      "display": "standalone",
      "startUrl": "/",
      "scope": "/"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
